# ============================================================
# ULTIMATE OMNICHANNEL E-COMMERCE - Environment Variables
# ============================================================

# Environment
ENV=production

# Database (Supabase PostgreSQL - Free Tier)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.peznevsvvmtdhafursvd.supabase.co:5432/postgres

# Security
SECRET_KEY=generate-a-32-char-random-secret-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=30

# Platform Mode
PLATFORM_MODE=ULTIMATE

# ============================================================
# PAYMENT APIs
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ============================================================
# AI SETTINGS
# ============================================================
OPENAI_API_KEY=

# ============================================================
# SMTP EMAIL
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# MARKETPLACE CREDENTIALS
# Set these to connect your seller accounts
# ============================================================

# Shopee Seller API
# Register at: https://partner.shopeemobile.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=

# Lazada Seller API
# Register at: https://open.lazada.com
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_ACCESS_TOKEN=
LAZADA_COUNTRY=vn

# TikTok Shop Seller API
# Register at: https://partner.tiktokshop.com
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_SHOP_ID=
TIKTOK_REGION=VN

# Facebook/Meta Commerce API
# Create app at: https://developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_CATALOG_ID=

# Sendo.vn API
# Contact: https://open.sendo.vn
SENDO_PARTNER_ID=
SENDO_PARTNER_KEY=
SENDO_SHOP_ID=

# ============================================================
# VERCEL DEPLOYMENT
# ============================================================
# Set via Vercel Dashboard > Settings > Environment Variables
# Never commit actual values to git

